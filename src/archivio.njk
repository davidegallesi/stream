---
layout: base.njk
pageTitle: Archivio — Stream
permalink: /archivio/
bodyClass: wide
---

<div class="filter-bar">
  <button class="filter-btn active" data-type="all">Tutti</button>
  <button class="filter-btn" data-type="note">Notes</button>
  <button class="filter-btn" data-type="link">Links</button>
  <button class="filter-btn" data-type="quote">Quotes</button>
  <button class="filter-btn" data-type="image">Images</button>
  <span class="year-select-wrap">
    <select id="year-select" class="year-select" aria-label="Filtra per anno">
      <option value="all">Tutti gli anni</option>
      {% for y in collections.stream | streamYears %}
      <option value="{{ y }}">{{ y }}</option>
      {% endfor %}
    </select>
    <svg class="year-select-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </span>
</div>

{% for post in collections.stream %}
<article class="post" data-type="{{ post.data.type }}" data-year="{{ post.date | year }}">
  <div class="post-meta">
    <span class="post-type {{ post.data.type }}" title="{{ post.data.type }}">
      {{ post.data.type | postIcon | safe }}
    </span>
    <time datetime="{{ post.date | htmlDateString }}">
      {{ post.date | dataLeggibile }} &middot; {{ post.date | ora }}
    </time>
    {% if post.data.type != "quote" and post.data.type != "link" and post.data.type != "image" %}
      {% set plainText = post.templateContent | stripHtml %}
      {% if plainText.length > 320 %}<a href="{{ post.url | url }}" class="more-link" title="Leggi il post completo">read more</a>{% endif %}
    {% endif %}
  </div>
  <div class="post-body">
    {% include "post-body.njk" %}
  </div>
</article>
{% endfor %}

<script>
  const buttons    = document.querySelectorAll('.filter-btn');
  const yearSelect = document.getElementById('year-select');
  const posts      = document.querySelectorAll('.post[data-type]');

  function applyFilters() {
    const type = document.querySelector('.filter-btn.active').dataset.type;
    const year = yearSelect.value;
    let lastVisible = null;
    posts.forEach(post => {
      const typeMatch = type === 'all' || post.dataset.type === type;
      const yearMatch = year === 'all' || post.dataset.year === year;
      const visible = typeMatch && yearMatch;
      post.style.display = visible ? '' : 'none';
      post.classList.remove('last-visible');
      if (visible) lastVisible = post;
    });
    if (lastVisible) lastVisible.classList.add('last-visible');
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });

  yearSelect.addEventListener('change', applyFilters);
</script>
