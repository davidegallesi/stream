---
layout: base.njk
pageTitle: Stream
---

{% set twoMonthsAgo = collections.stream | twoMonthsAgo %}

{% for post in collections.stream %}
  {% if post.date >= twoMonthsAgo %}
  <article class="post">
    <div class="post-meta">
      <span class="post-type {{ post.data.type }}" title="{{ post.data.type }}">
        {{ post.data.type | postIcon | safe }}
      </span>
      <time datetime="{{ post.date | htmlDateString }}">
        {{ post.date | dataLeggibile }} &middot; {{ post.date | ora }}
      </time>
      {% if post.data.type != "quote" and post.data.type != "link" and post.data.type != "image" %}
        {% set plainText = post.templateContent | stripHtml %}
        {% if plainText.length > 320 %}<a href="{{ post.url | url }}" class="more-link" title="Leggi il post completo">read more</a>{% endif %}
      {% endif %}
    </div>
    <div class="post-body">
      {% include "post-body.njk" %}
    </div>
  </article>
  {% endif %}
{% endfor %}
