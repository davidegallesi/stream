---
layout: base.njk
pageTitle: Stream
bodyClass: home
---

{% set lastNote  = collections.stream_note  | first %}
{% set lastLink  = collections.stream_link  | first %}
{% set lastQuote = collections.stream_quote | first %}

<div class="home-grid">

  <div class="home-col-left">

    {% if lastNote %}
    {% set post = lastNote %}
    <article class="post">
      <div class="post-meta">
        <span class="post-type {{ post.data.type }}" title="{{ post.data.type }}">
          {{ post.data.type | postIcon | safe }}
        </span>
        <time datetime="{{ post.date | htmlDateString }}">
          {{ post.date | dataLeggibile }} &middot; {{ post.date | ora }}
        </time>
        {% set plainText = post.templateContent | stripHtml %}
        {% if plainText.length > 320 %}<a href="{{ post.url | url }}" class="more-link" title="Leggi il post completo">read more</a>{% endif %}
      </div>
      <div class="post-body">
        {% include "post-body.njk" %}
      </div>
    </article>
    {% endif %}

    {% if lastLink %}
    {% set post = lastLink %}
    <article class="post">
      <div class="post-meta">
        <span class="post-type {{ post.data.type }}" title="{{ post.data.type }}">
          {{ post.data.type | postIcon | safe }}
        </span>
        <time datetime="{{ post.date | htmlDateString }}">
          {{ post.date | dataLeggibile }} &middot; {{ post.date | ora }}
        </time>
      </div>
      <div class="post-body">
        {% include "post-body.njk" %}
      </div>
    </article>
    {% endif %}

    {% if lastQuote %}
    {% set post = lastQuote %}
    <article class="post">
      <div class="post-meta">
        <span class="post-type {{ post.data.type }}" title="{{ post.data.type }}">
          {{ post.data.type | postIcon | safe }}
        </span>
        <time datetime="{{ post.date | htmlDateString }}">
          {{ post.date | dataLeggibile }} &middot; {{ post.date | ora }}
        </time>
      </div>
      <div class="post-body">
        {% include "post-body.njk" %}
      </div>
    </article>
    {% endif %}

  </div>

  <div class="home-col-right">
    <article class="post" id="random-image"></article>
  </div>

</div>

<script type="application/json" id="image-data">
[{% for post in collections.stream_image %}{"src":"{{ post.data.image | url }}","alt":"{{ post.data.imageAlt or '' }}","caption":"{{ post.templateContent | stripHtml | replace('"', '&quot;') }}"}{% if not loop.last %},{% endif %}{% endfor %}]
</script>

<script>
(function () {
  var data = JSON.parse(document.getElementById('image-data').textContent);
  if (!data.length) return;
  var item = data[Math.floor(Math.random() * data.length)];
  var fig = '<figure class="post-image"><img src="' + item.src + '" alt="' + item.alt + '" loading="lazy">';
  if (item.caption) fig += '<figcaption>' + item.caption + '</figcaption>';
  fig += '</figure>';
  document.getElementById('random-image').innerHTML = '<div class="post-body">' + fig + '</div>';
})();
</script>
