---
permalink: /feed/image.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Stream — image</title>
  <subtitle>Solo post di tipo image.</subtitle>
  <link href="{{ site.siteUrl }}/feed/image.xml" rel="self"/>
  <link href="{{ site.siteUrl }}/"/>
  <id>{{ site.siteUrl }}/feed/image/</id>
  {% if collections.stream_image.length %}
  <updated>{{ collections.stream_image[0].date | rfc3339 }}</updated>
  {% endif %}
  {% for post in collections.stream_image | head(20) %}
  <entry>
    <title>image — {{ post.date | htmlDateString }}</title>
    <link href="{{ site.siteUrl }}{{ post.url }}"/>
    <id>{{ site.siteUrl }}{{ post.url }}</id>
    <updated>{{ post.date | rfc3339 }}</updated>
    <content type="html"><![CDATA[{% if post.data.image %}<figure><img src="{{ site.siteUrl }}{{ post.data.image }}" alt="{{ post.data.imageAlt or '' }}" /></figure>{% endif %}{{ post.templateContent | safe }}]]></content>
  </entry>
  {% endfor %}
</feed>
