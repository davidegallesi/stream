{% if post.data.type == "quote" %}
  <blockquote>
    {{ post.templateContent | safe }}
    {% if post.data.author %}<cite>— {{ post.data.author }}</cite>{% endif %}
  </blockquote>

{% elif post.data.type == "link" %}
  <a class="external-link" href="{{ post.data.url }}" target="_blank" rel="noopener">
    ↗ {{ post.data.linkTitle or post.data.url }}
  </a>
  {% if post.templateContent %}<p class="link-desc">{{ post.templateContent | safe }}</p>{% endif %}

{% elif post.data.type == "image" %}
  {% if post.data.image %}
  <figure class="post-image">
    <img src="{{ post.data.image | url }}" alt="{{ post.data.imageAlt or '' }}" loading="lazy" />
    {% if post.templateContent %}<figcaption>{{ post.templateContent | safe }}</figcaption>{% endif %}
  </figure>
  {% endif %}

{% else %}
  {% set plainText = post.templateContent | stripHtml %}
  {% if plainText.length > 160 %}
    <p class="note-preview">{{ plainText | truncateChars(160) }} <a href="{{ post.url | url }}" class="more-link post-type note" title="Leggi il post completo"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M13 7C13 6.44772 12.5523 6 12 6C11.4477 6 11 6.44772 11 7V11H7C6.44772 11 6 11.4477 6 12C6 12.5523 6.44772 13 7 13H11V17C11 17.5523 11.4477 18 12 18C12.5523 18 13 17.5523 13 17V13H17C17.5523 13 18 12.5523 18 12C18 11.4477 17.5523 11 17 11H13V7Z" fill="currentColor"/></svg></a></p>
  {% else %}
    {{ post.templateContent | safe }}
  {% endif %}
{% endif %}
